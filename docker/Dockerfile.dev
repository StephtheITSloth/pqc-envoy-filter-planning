# Development Docker container for PQC Envoy Filter
# Includes Bazel, build tools, and all dependencies
FROM envoyproxy/envoy-build-ubuntu:latest

# Set working directory
WORKDIR /workspace

# Install additional development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    vim \
    git \
    curl \
    wget \
    tree \
    htop \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Bazelisk (manages Bazel versions)
RUN wget -O /usr/local/bin/bazel https://github.com/bazelbuild/bazelisk/releases/download/v1.19.0/bazelisk-linux-amd64 \
    && chmod +x /usr/local/bin/bazel

# Set up Bazel cache directory
RUN mkdir -p /root/.cache/bazel

# Copy workspace files
COPY WORKSPACE .bazelrc ./
COPY src/ ./src/
COPY test/ ./test/

# Default command
CMD ["/bin/bash"]
