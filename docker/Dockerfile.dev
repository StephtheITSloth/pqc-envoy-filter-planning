# Development Docker container for PQC Envoy Filter
# Includes Bazel, build tools, and all dependencies.
# Pin the current pullable Envoy dev image by digest for reproducible CI.
FROM envoyproxy/envoy-dev@sha256:d0d3873487c5184b4fc84b7b708019687a2fb58390f75358c685e7bba93e5a44

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    vim \
    git \
    curl \
    wget \
    tree \
    htop \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN wget -O /usr/local/bin/bazel https://github.com/bazelbuild/bazelisk/releases/download/v1.19.0/bazelisk-linux-amd64 \
    && chmod +x /usr/local/bin/bazel

RUN mkdir -p /root/.cache/bazel

COPY WORKSPACE BUILD.bazel .bazelrc .bazelversion ./
COPY src/ ./src/
COPY test/ ./test/

RUN chown -R envoy:envoy /workspace

CMD ["/bin/bash"]
