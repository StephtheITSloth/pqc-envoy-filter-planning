{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PQC Agent Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "reason"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "allow",
        "prefer_hybrid",
        "fallback",
        "deny"
      ]
    },
    "reason": {
      "type": "string"
    }
  }
}
