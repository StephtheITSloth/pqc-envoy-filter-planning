{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PQC Agent Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "service_name",
    "request_method",
    "request_path",
    "pqc_capable",
    "mode"
  ],
  "properties": {
    "service_name": {
      "type": "string",
      "description": "Normalized service identifier derived from authority first, then SNI."
    },
    "authority": {
      "type": "string"
    },
    "request_method": {
      "type": "string"
    },
    "request_path": {
      "type": "string"
    },
    "client_ip": {
      "type": "string"
    },
    "sni": {
      "type": "string"
    },
    "tls_version": {
      "type": "string"
    },
    "cipher_suite": {
      "type": "string"
    },
    "pqc_capable": {
      "type": "boolean"
    },
    "mode": {
      "type": "string",
      "enum": [
        "classical",
        "hybrid",
        "pqc_only"
      ]
    }
  }
}
